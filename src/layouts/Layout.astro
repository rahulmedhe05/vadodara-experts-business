---
import { niches } from "@/lib/data";
import { VADODARA_AREAS } from "@/lib/areas";
import "../styles/globals.css";

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  schemas?: Record<string, any>[];
}

const {
  title,
  description,
  keywords = "best professional services in Vadodara, certified experts, same-day service",
  canonical = "https://vadodaraexperts.com",
  ogTitle,
  ogDescription,
  ogUrl,
  schemas = []
} = Astro.props;

// Group niches by category for footer
function groupByCategory(list: typeof niches) {
  const map: Record<string, typeof niches> = {};
  for (const n of list) {
    if (!map[n.category]) map[n.category] = [];
    map[n.category].push(n);
  }
  return map;
}

const grouped = groupByCategory(niches);
const yr = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {/* Favicon & Icons */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" sizes="32x32" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#4f46e5" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph / Facebook */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VadodaraExperts" />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:url" content={ogUrl || canonical} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />

    {/* Schema.org JSON-LD scripts */}
    {schemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    {/* ===== HEADER ===== */}
    <header class="header">
      <nav class="header-nav">
        <a href="/" class="logo">
          <svg width="42" height="42" viewBox="0 0 32 32" style="display:inline-block;vertical-align:middle;margin-right:10px;flex-shrink:0" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="hg-h" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#4f46e5"/>
                <stop offset="100%" stop-color="#7c3aed"/>
              </linearGradient>
            </defs>
            <polygon points="16,1 29,8.5 29,23.5 16,31 3,23.5 3,8.5" fill="url(#hg-h)"/>
            <polygon points="16,3.5 27,9.75 27,22.25 16,28.5 5,22.25 5,9.75" fill="none" stroke="#06b6d4" stroke-width="1"/>
            <text x="16" y="21" text-anchor="middle" font-family="Arial Black,Arial,sans-serif" font-weight="900" font-size="11" fill="#ffffff" letter-spacing="-0.5">VE</text>
          </svg>
          Vadodara<span class="logo-accent">Experts</span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
        <a href="/contact" class="header-cta">
          Get a Quote
        </a>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    {/* ===== FOOTER ===== */}
    <footer class="footer">
      <div class="footer-top">
        <div class="footer-container">
          {/* Brand Column */}
          <div class="footer-brand">
            <a href="/" class="footer-logo">
              <svg width="28" height="28" viewBox="0 0 32 32" style="display:inline-block;vertical-align:middle;margin-right:8px;flex-shrink:0" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="hg-f" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#4f46e5"/>
                    <stop offset="100%" stop-color="#7c3aed"/>
                  </linearGradient>
                </defs>
                <polygon points="16,1 29,8.5 29,23.5 16,31 3,23.5 3,8.5" fill="url(#hg-f)"/>
                <polygon points="16,3.5 27,9.75 27,22.25 16,28.5 5,22.25 5,9.75" fill="none" stroke="#06b6d4" stroke-width="1"/>
                <text x="16" y="21" text-anchor="middle" font-family="Arial Black,Arial,sans-serif" font-weight="900" font-size="11" fill="#ffffff" letter-spacing="-0.5">VE</text>
              </svg>
              Vadodara<span class="logo-accent">Experts</span>
            </a>
            <p class="footer-brand-desc">
              Vadodara's leading professional services company. We deliver expert solutions across 200+ service categories with quality, reliability, and trust.
            </p>
            <div class="footer-contact-info">
              <p>Vadodara, Gujarat, India</p>
              <p>info@vadodaraexperts.com</p>
            </div>
          </div>

          {/* Quick Links */}
          <div class="footer-col">
            <h4 class="footer-heading">Company</h4>
            <ul class="footer-links">
              <li><a href="/">Home</a></li>
              <li><a href="/about">About Us</a></li>
              <li><a href="/contact">Contact Us</a></li>
            </ul>
          </div>

          {/* Service Categories — show top 6 per category to control crawl budget */}
          {Object.entries(grouped).map(([cat, items]) => (
            <div class="footer-col">
              <h4 class="footer-heading">{cat}</h4>
              <ul class="footer-links">
                {items.slice(0, 6).map((n) => (
                  <li>
                    <a href={`/${n.slug}`}>{n.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      {/* Areas */}
      <div class="footer-areas">
        <div class="footer-areas-container">
          <h4 class="footer-heading">Areas We Serve in Vadodara</h4>
          <div class="footer-area-tags">
            {VADODARA_AREAS.map((area) => (
              <a href={`/${area.slug}/ac-services`} class="footer-area-tag">{area.name}</a>
            ))}
          </div>
        </div>
      </div>

      {/* Bottom Bar */}
      <div class="footer-bottom">
        <p>&copy; {yr} VadodaraExperts.com. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
